# urban-vision — configuración de ejemplo. Copiar a `.env` (NO subir `.env`).
# Todas las variables llevan el prefijo VISION_ (ver app/config.py).

# ── Servicio ────────────────────────────────────────────────────────────────
VISION_ENV=development                # development|staging|production
VISION_HOST=0.0.0.0
VISION_PORT=8200
VISION_LOG_LEVEL=info

# ── Seguridad del canal Backend ↔ Vision (Req 10.1) ──────────────────────────
# Obligatorio en producción. En dev puede quedar vacío (auth omitida).
VISION_SERVICE_TOKEN=

# ── Inferencia (Req 1.6) ──────────────────────────────────────────────────────
# cpu | directml (GPU AMD/Windows dev) | cuda (GPU NVIDIA prod) | tensorrt
VISION_EXECUTION_PROVIDER=cpu
VISION_EMBEDDING_MODEL=arcface        # arcface | adaface
VISION_EMBEDDING_DIM=512
VISION_MODELS_DIR=/models

# ── Umbrales fallback (los efectivos los manda el Backend por Access_Point) ──
VISION_DEFAULT_MATCH_THRESHOLD=0.5
VISION_DEFAULT_LIVENESS_THRESHOLD=0.7
VISION_MIN_FACE_QUALITY=0.5

# ── Vector_Store (Qdrant) — Req 9.1 ──────────────────────────────────────────
VISION_QDRANT_URL=http://qdrant:6333
VISION_QDRANT_API_KEY=
VISION_QDRANT_COLLECTION_PREFIX=faces_
