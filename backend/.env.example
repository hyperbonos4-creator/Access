# ── Office Access Control — Backend ──────────────────────────────────────────
# Copiar a `.env`. NUNCA subir `.env` ni secretos al repo.

NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3001
# Swagger: en producción queda apagado salvo SWAGGER_ENABLED=true.
SWAGGER_ENABLED=true

# ── Identidad del sitio ───────────────────────────────────────────────────────
# Reemplaza el multi-tenant `conjuntoId` de URBAN. Una sola oficina = un SITE_ID.
# Se usa como espacio de nombres de la colección de Qdrant (faces_<SITE_ID>).
SITE_ID=office

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=access
DB_PASSWORD=access
DB_NAME=access_control
# true solo en dev: crea/actualiza el esquema desde las entidades.
DB_SYNCHRONIZE=true

# ── JWT (mínimo 16 caracteres; sin placeholders en producción) ────────────────
JWT_ACCESS_SECRET=change_me_dev_only_min_16_chars
# Vida del access token. El token de kiosko (terminal) usa 30d aparte.
JWT_ACCESS_TTL=12h

# ── Admin inicial (lo crea `npm run seed`) ────────────────────────────────────
SEED_ADMIN_EMAIL=admin@office.local
SEED_ADMIN_PASSWORD=ChangeMe123!

# ── Autorización ──────────────────────────────────────────────────────────────
# Puerta única: un empleado enrolado queda habilitado automáticamente en las
# puertas (sin paso manual de "autorizar"). Poner 'false' para gestión explícita
# de permisos por punto (modelo multi-puerta con horarios).
AUTO_AUTHORIZE_ENROLLED=true

# Ventana de apertura de la puerta (ms): tras conceder, permanece ABIERTA este
# tiempo y luego re-bloquea automáticamente (estado en vivo del kiosko/admin).
DOOR_OPEN_HOLD_MS=6000

# ── Vision_Service (microservicio facial) ─────────────────────────────────────
VISION_SERVICE_URL=http://localhost:8200
VISION_SERVICE_TOKEN=
VISION_SERVICE_TIMEOUT_MS=5000
# Timeout ampliado para el liveness ACTIVO (revalida varios fotogramas con
# InsightFace; en CPU tarda más que un /recognize de un solo frame).
VISION_ACTIVE_LIVENESS_TIMEOUT_MS=45000

# ── Cámara IP (snapshot ISAPI / RTSP) ─────────────────────────────────────────
# Puerto HTTP del ISAPI de la cámara para snapshots (Hikvision/Dahua ONVIF).
CAMERA_ISAPI_PORT=80

# ── Vista remota "Cámara en vivo" (familiar) ──────────────────────────────────
# Si está vacío, la vista queda DESHABILITADA. Acceso = HTTPS + login nginx +
# este secreto en el enlace. Genera uno largo y aleatorio.
FAMILY_STREAM_SECRET=
# Punto de acceso cuya cámara se transmite (vacío = el primero con cámara).
FAMILY_ACCESS_POINT_ID=
